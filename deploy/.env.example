# Host bind address for published port
BIND_HOST=0.0.0.0

# Web server listen port
ACLIV_PORT=17860

# Set to 0/false to disable web login entirely.
ACLIV_WEB_AUTH_ENABLED=1

# Web login credentials
ACLIV_WEB_USERNAME=admin
ACLIV_WEB_PASSWORD=

# Persist search.db and related runtime data in the mounted app_data volume
ACLIV_HOME=/app/data

# Remote image configuration for Linux production deployment
# The target server only pulls and runs the GHCR image.
ACLIV_IMAGE=ghcr.io/occva/acliv
ACLIV_VERSION=1.0.6

# Keep container running as root when source data is root-owned and unreadable by UID 1000
ACLIV_RUN_AS_ROOT=0

# Provider-specific host directories.
# Point each variable at the provider root, not the parent home directory.
# Examples:
#   CLAUDE_DIR=/root/.claude
#   CODEX_DIR=/root/.codex
#   GEMINI_DIR=/root/.gemini
#   OPENCLAW_DIR=/root/.openclaw
#   OPENCODE_DIR=/root/.config/opencode
CLAUDE_DIR=
CODEX_DIR=
GEMINI_DIR=
OPENCLAW_DIR=
OPENCODE_DIR=

# Legacy fallback used by install.sh to auto-populate provider paths when the
# individual provider variables are empty.
HOST_HOME=

# Timezone
TZ=Asia/Shanghai
